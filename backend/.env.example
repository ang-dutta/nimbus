# Server
NODE_ENV=development
PORT=4000

# PostgreSQL (Supabase or Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/nimbus

# AWS S3 (or LocalStack endpoint for local dev)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=nimbus-files
# Uncomment for local dev with LocalStack:
# S3_ENDPOINT=http://localstack:4566

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Realtime DB (for real-time notifications)
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com

# JWT (used for share link tokens — Firebase handles user auth JWTs)
JWT_SECRET=change_this_to_a_long_random_string_in_production

# SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@nimbus.app

# App URL (for links in emails)
APP_URL=http://localhost:3000

# Storage quota per user (bytes) — default 5GB
DEFAULT_STORAGE_QUOTA_BYTES=5368709120

# Anomaly detection thresholds
ANOMALY_SPIKE_STDDEV_THRESHOLD=3.0
ANOMALY_FAILED_PASSWORD_ATTEMPTS=5
ANOMALY_SPIKE_WINDOW_MINUTES=5
